// STATE
let qs=[],idx=0,score=0,answers=[],done=false,qty=10,mode='lesson',lesson=null;

// NAV
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+id).classList.add('active');
  window.scrollTo(0,0);
}
function goHome(){showScreen('home')}
function showSetup(){showScreen('setup')}

// THEME
function toggleTheme(){
  const h=document.documentElement,dark=h.dataset.theme==='dark';
  h.dataset.theme=dark?'light':'dark';
  document.getElementById('themeBtn').textContent=dark?'🌙 Tối':'☀️ Sáng';
  localStorage.setItem('theme',h.dataset.theme);
}

// SETUP
function pickQty(btn,q){
  document.querySelectorAll('.qty-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); qty=q;
}

// START
function startLesson(l){
  lesson=l; mode='lesson';
  qs=[...QDB[l]];
  begin();
}

function startRandom(){
  const checks=[...document.querySelectorAll('.lchk:checked')];
  if(!checks.length){toast('Vui lòng chọn ít nhất một bài học!');return;}
  mode='random';
  let pool=[];
  checks.forEach(c=>pool.push(...QDB[c.value]));
  const easy=shuffle(pool.filter(q=>q.d==='easy'));
  const med=shuffle(pool.filter(q=>q.d==='medium'));
  const hard=shuffle(pool.filter(q=>q.d==='hard'));
  let ordered=[...easy,...med,...hard];
  if(qty!=='all') ordered=ordered.slice(0,qty);
  qs=ordered;
  begin();
}

function shuffle(a){
  const b=[...a];
  for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}
  return b;
}

function begin(){
  idx=0;score=0;answers=[];done=false;
  showScreen('quiz');
  render();
}

// RENDER
function render(){
  const q=qs[idx],total=qs.length;
  document.getElementById('progBar').style.width=((idx/total)*100)+'%';
  document.getElementById('qCounter').textContent=`Câu ${idx+1} / ${total}`;
  document.getElementById('scoreTrack').textContent=`✓ ${score} đúng`;
  document.getElementById('qText').textContent=q.q;
  const ol=document.getElementById('optsList');
  ol.innerHTML='';
  q.o.forEach((opt,i)=>{
    const d=document.createElement('div');
    d.className='opt';
    d.onclick=()=>pick(i);
    d.innerHTML=`<span class="oletter">${L[i]}</span><span class="otext">${opt}</span>`;
    ol.appendChild(d);
  });
  const fb=document.getElementById('fbBox');
  fb.className='fb'; fb.style.display='none'; fb.textContent='';
  const nb=document.getElementById('nextBtn');
  nb.disabled=true;
  nb.textContent=idx===total-1?'Xem kết quả →':'Câu tiếp →';
  done=false;
}

function pick(i){
  if(done)return;
  done=true;
  const q=qs[idx],correct=q.a,ok=i===correct;
  if(ok)score++;
  answers[idx]={sel:i,correct,ok};
  document.querySelectorAll('.opt').forEach((o,j)=>{
    o.classList.add('done');
    if(j===correct)o.classList.add('right');
    if(j===i&&!ok)o.classList.add('wrong');
  });
  const fb=document.getElementById('fbBox');
  fb.className='fb '+(ok?'ok':'err');
  fb.style.display='flex';
  fb.innerHTML=ok
    ?'<span>✅ Chính xác!</span>'
    :`<span>❌ Sai rồi! Đáp án đúng là: <strong>${L[correct]}. ${q.o[correct]}</strong></span>`;
  document.getElementById('nextBtn').disabled=false;
  document.getElementById('scoreTrack').textContent=`✓ ${score} đúng`;
}

function nextQ(){
  if(!done)return;
  idx++;
  if(idx>=qs.length)showResults();
  else render();
}

// RESULTS
function showResults(){
  const total=qs.length,pct=Math.round((score/total)*100);
  const deg=(score/total)*360;
  document.getElementById('donut').style.background=
    `conic-gradient(var(--primary) ${deg}deg, var(--border) ${deg}deg)`;
  document.getElementById('resNum').textContent=`${score}/${total}`;
  document.getElementById('rCorrect').textContent=score;
  document.getElementById('rWrong').textContent=total-score;
  document.getElementById('rPct').textContent=pct+'%';
  const title=pct>=90?'🎉 Xuất sắc!':pct>=75?'👏 Rất tốt!':pct>=60?'👍 Khá tốt!':'💪 chúc mừng b làm bài như cc!';
  document.getElementById('resTitle').textContent=title;
  document.getElementById('resSub').textContent=`Bạn đúng ${score}/${total} câu (${pct}%)`;
  const rl=document.getElementById('revList');
  rl.innerHTML='';
  qs.forEach((q,i)=>{
    const ua=answers[i]||{sel:-1,correct:q.a,ok:false};
    const d=document.createElement('div');
    d.className='rev-item '+(ua.ok?'ok':'err');
    d.innerHTML=`<div class="rev-q">${i+1}. ${q.q}</div>
      <div class="rev-a">${ua.ok
        ?`✅ Đúng: ${L[ua.correct]}. ${q.o[ua.correct]}`
        :`❌ Bạn chọn: ${ua.sel>=0?L[ua.sel]+'. '+q.o[ua.sel]:'Chưa trả lời'}<br>✅ Đáp án: ${L[ua.correct]}. ${q.o[ua.correct]}`
      }</div>`;
    rl.appendChild(d);
  });
  document.getElementById('revList').style.display='none';
  document.getElementById('revIcon').textContent='▼';
  showScreen('results');
}

function toggleRev(btn){
  const rl=document.getElementById('revList');
  const hide=rl.style.display==='none';
  rl.style.display=hide?'flex':'none';
  document.getElementById('revIcon').textContent=hide?'▲':'▼';
}

function retryQuiz(){
  if(mode==='lesson')startLesson(lesson);
  else{qs=shuffle(qs);begin();}
}

function confirmQuit(){
  if(idx>0||done){if(confirm('Thoát? Tiến độ sẽ không được lưu.'))goHome();}
  else goHome();
}

// TOAST
function toast(msg,ms=3000){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),ms);
}

// KEYBOARD
document.addEventListener('keydown',e=>{
  if(!document.getElementById('screen-quiz').classList.contains('active'))return;
  if(['1','2','3','4'].includes(e.key)&&!done)pick(+e.key-1);
  if((e.key==='Enter'||e.key==='ArrowRight')&&done)nextQ();
});

// INIT
(()=>{
  const t=localStorage.getItem('theme');
  if(t){document.documentElement.dataset.theme=t;document.getElementById('themeBtn').textContent=t==='dark'?'☀️ Sáng':'🌙 Tối';}
})();
</script>
